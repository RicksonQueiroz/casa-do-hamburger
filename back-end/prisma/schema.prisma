generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String
  password String
  cep String
  admin Boolean @default(false)
}
model Product{
  id Int @id @default(autoincrement())
  name String
  description String
  price Int
  image String
  createdAt DateTime @default(now())
  category String @default("")
}